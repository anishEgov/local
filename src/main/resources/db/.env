# flyway -url=$DB_URL -table=$SCHEMA_TABLE -user=$FLYWAY_USER -password=$FLYWAY_PASSWORD -locations=$FLYWAY_LOCATIONS -baselineOnMigrate=true -outOfOrder=true migrate

export DB_URL=jdbc:postgresql://localhost:5432/egov-localization
export SCHEMA_TABLE=flyway_schema_history
export FLYWAY_USER=postgres
export FLYWAY_PASSWORD=1234
export FLYWAY_LOCATIONS=filesystem:./migration/ddl
